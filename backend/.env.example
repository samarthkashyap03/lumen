# Backend Environment Variables

# Supabase Production Credentials
SUPABASE_URL="https://your-project-id.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Groq AI Key (for the multi-agent pipeline)
GROQ_API_KEY="gsk_..."

# Redis URL (Required for Celery background tasks in production)
REDIS_URL="redis://localhost:6379/0"

# Optional: Disable Celery locally even if Supabase is active (defaults to False if not set)
# USE_CELERY="False"
